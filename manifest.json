{
  "manifest_version": 3,
  "name": "Substack Reader",
  "version": "1.0.0",
  "description": "Reading progress bar and ADHD-friendly highlighting for Substack",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://substack.com/*", "*://*.substack.com/*"],
  "content_scripts": [
    {
      "matches": ["*://substack.com/*", "*://*.substack.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Substack Reader"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
